# Ezkey Demo API — copy to `apps/demo-api/.env` and fill in real values.
# `main.ts` loads this file at startup. Never commit `.env`.

# Integration API base URL (no trailing slash). Default if unset: EXP1 (https://exp1-integration-api.ezkey.org). Use http://localhost:7080 for a local stack.
EZKEY_BASE_URL=https://exp1-integration-api.ezkey.org

# API key pair from Ezkey Admin UI (Integration → API keys). Machine-to-machine (HTTP Basic).
EZKEY_INTEGRATION_KEY=ezkey_ikey_REPLACE_ME
EZKEY_SECRET_KEY=ezkey_skey_REPLACE_ME

# Browser origin(s) allowed to call this API (CORS). Comma-separated for multiple origins.
# Must match the demo UI dev server (Vite default: http://localhost:5173).
DEMO_UI_ORIGIN=http://localhost:5173

# HTTP port for this API (default: 3000)
# PORT=3000
